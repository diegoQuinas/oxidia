# Tibia server configuration (protocol 10.98)

[server]
world_name = "Oxidia"
# Address advertised to the client in the character list. Must be an address the
# client can actually reach (127.0.0.1 for local play, or the LAN/public IP for
# remote clients) — NOT a bind wildcard like 0.0.0.0. The interface the server
# listens on is configured separately via [network].bind.
host = "127.0.0.1"
motd = "Welcome to Oxidia"

[world]
# Path to the .otbm map, relative to the working directory or absolute.
# The server refuses to start if this file is missing or fails to parse.
map_path = "reference/tfs/data/world/map.otbm"
# Town whose temple players spawn at. Falls back to the map's first town if unset
# or unknown. The 1098 real map ships Ab'Dendriel at temple (32732, 31634, 7).
spawn_town = "Dawnport"


[network]
# Login protocol (7171) and game protocol (7172).
login_port = 7171
game_port = 7172
# Interface the listeners bind to.
bind = "0.0.0.0"

[database]
path = "oxidia.db"

[log]
# tracing EnvFilter directive; RUST_LOG overrides this if set.
filter = "info"
